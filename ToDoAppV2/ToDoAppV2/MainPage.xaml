<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:todo="clr-namespace:ToDoMaui_Listview"
             x:Class="listView_Corsega.MainPage"
             Title="ToDo"
             BackgroundColor="#F2F4F8">

    <Grid Padding="16,12,16,0" RowDefinitions="Auto,Auto,*">
        <Label Grid.Row="0"
               Text="ToDo"
               FontFamily="OpenSansSemibold"
               FontSize="34"
               HorizontalOptions="Center"
               TextColor="#A6ACB6" />

        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 Margin="0,6,0,12"
                 BackgroundColor="#D5DAE2" />

        <Grid Grid.Row="2">
            <CollectionView x:Name="todoCV"
                            SelectionMode="None"
                            ItemsLayout="VerticalList"
                            ItemsSource="{Binding}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="No tasks yet" FontFamily="OpenSansSemibold" FontSize="18" TextColor="#8B95A5" HorizontalTextAlignment="Center" />
                        <Label Text="Tap + to add your first task" FontSize="14" TextColor="#A4AABA" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="todo:ToDoClass">
                        <Border Margin="0,6"
                                Padding="14,12"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#D1D8E3"
                                BackgroundColor="White">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OpenEditPage" CommandParameter="{Binding id}" />
                            </Border.GestureRecognizers>
                            <Border.Shadow>
                                <Shadow Opacity="0.14" Radius="8" Offset="0,2" Brush="#000000" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       Text="{Binding title}"
                                       VerticalOptions="Center"
                                       FontSize="28"
                                       FontFamily="OpenSansRegular"
                                       TextColor="#1E2430"
                                       LineBreakMode="TailTruncation" />

                                <Border Grid.Column="1"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    Padding="0"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#D9E0EC"
                                    BackgroundColor="#F8FAFD">
                                    <ImageButton ClassId="{Binding id}"
                                                 BackgroundColor="Transparent"
                                                 Padding="8"
                                                 Clicked="DeleteToDoItem">
                                        <ImageButton.Source>
                                            <FontImageSource Glyph="✕"
                                                             Size="14"
                                                             Color="#6B7280"
                                                             FontFamily="OpenSansSemibold" />
                                        </ImageButton.Source>
                                    </ImageButton>
                                </Border>

                                <Border Grid.Column="2"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    Padding="0"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#D5DCF2"
                                    BackgroundColor="#EEF2FF">
                                    <ImageButton ClassId="{Binding id}"
                                                 BackgroundColor="Transparent"
                                                 Padding="8"
                                                 Clicked="CompleteToDoItem">
                                        <ImageButton.Source>
                                            <FontImageSource Glyph="✓"
                                                             Size="16"
                                                             Color="#4F46E5"
                                                             FontFamily="OpenSansSemibold" />
                                        </ImageButton.Source>
                                    </ImageButton>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+"
                    Clicked="AddToDoItem"
                    WidthRequest="56"
                    HeightRequest="56"
                    CornerRadius="16"
                    FontSize="28"
                    Margin="0,0,10,16"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    FontFamily="OpenSansSemibold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </Grid>
    </Grid>

</ContentPage>
