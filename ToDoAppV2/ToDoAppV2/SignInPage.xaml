<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="listView_Corsega.SignInPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F4F7FB">
    <ContentPage.Resources>
        <Color x:Key="PageTextPrimary">#1E293B</Color>
        <Color x:Key="PageTextMuted">#64748B</Color>
        <Color x:Key="InputBorder">#DCE3ED</Color>
        <Color x:Key="PrimaryButton">#8D8ED9</Color>
        <Color x:Key="SecondaryButton">#ECECFF</Color>
        <Color x:Key="SecondaryButtonText">#6E71C4</Color>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="26,16,26,28"
              RowDefinitions="Auto,*"
              RowSpacing="24">

            <Grid Grid.Row="0" />

            <VerticalStackLayout Grid.Row="1"
                                 VerticalOptions="Center"
                                 Spacing="12">

                <Border HeightRequest="190"
                        WidthRequest="250"
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        BackgroundColor="#E8EEF5"
                        StrokeShape="RoundRectangle 18">
                    <Image Source="icon.png"
                           Aspect="AspectFit"
                           Margin="12" />
                </Border>

                <VerticalStackLayout Margin="0,12,0,0" Spacing="10">
                    <Border Stroke="{StaticResource InputBorder}" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="12,4">
                        <Entry x:Name="EmailEntry" Placeholder="Email address" Keyboard="Email" TextColor="{StaticResource PageTextPrimary}" PlaceholderColor="{StaticResource PageTextMuted}" />
                    </Border>

                    <Border Stroke="{StaticResource InputBorder}" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="12,4">
                        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" Keyboard="Text" TextColor="{StaticResource PageTextPrimary}" PlaceholderColor="{StaticResource PageTextMuted}" />
                    </Border>

                    <Button Text="Sign in"
                            Margin="0,4,0,0"
                            CornerRadius="10"
                            FontFamily="OpenSansSemibold"
                            BackgroundColor="{StaticResource PrimaryButton}"
                            TextColor="White"
                            Clicked="OnSignInClicked" />

                    <Button Text="Sign up"
                            CornerRadius="10"
                            FontFamily="OpenSansSemibold"
                            BackgroundColor="{StaticResource SecondaryButton}"
                            TextColor="{StaticResource SecondaryButtonText}"
                            Clicked="OnGoToSignUpClicked" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
